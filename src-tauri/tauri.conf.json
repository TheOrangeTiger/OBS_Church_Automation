{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OBS Church Automator",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "ui",
    "devUrl": "127.0.0.1:3000",
    "beforeDevCommand": "cargo tauri dev",
    "beforeBuildCommand": "cargo tauri build"
  },
  "app": {
    "windows": [
      {
        "title": "automator",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
