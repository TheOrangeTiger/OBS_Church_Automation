    {
      "name": "txt_Acknowledgment of the Land",
      "id": "text_gdiplus",
      "settings": {
        "text": " Acknowledgment of the Land \n Trinity Lutheran Church acknowledges that \n we live and worship on the traditional \n territories of the Indigenous peoples of \n the Treaty 6 region and the Métis Nation \n of Alberta, Region 4. Together we call \n upon all of our collective, honoured \n traditions and spirits to work in \n continuing right relationship that we may \n create a more vibrant, healthy community \n for today and future generations. ",
        "align": "left",
        "color": 4278190080,
        "bk_color": 4294967295,
        "bk_opacity": 75,
        "font": {
          "size": 50
        }
      }
